@model dotnetTest.Models.ProjectInfo

@{
    ViewData["Title"] = "Create Project";
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create New Project</title>
    <link href="https://cdn.jsdelivr.net/npm/select2@4.0.13/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/select2@4.0.13/dist/js/select2.min.js"></script>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f4f4;
            margin: 0;
            padding: 0;
            text-align: center;
        }
        .container {
            max-width: 800px;
            margin: 20px auto;
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }
        h2 {
            color: #2c2c8f;
        }
        .date-group {
            display: flex;
            justify-content: center;
            gap: 10px;
            margin-bottom: 20px;
        }
        .form-group {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            margin-top: 20px;
        }
        .form-group div {
            width: 48%;
            border: 2px solid #2c2c8f;
            padding: 15px;
            border-radius: 8px;
        }
        label {
            display: block;
            margin-top: 10px;
            font-weight: bold;
            text-align: left;
        }
        input, textarea, select {
            width: calc(100% - 16px);
            padding: 8px;
            margin-top: 5px;
            border: 1px solid #ccc;
            border-radius: 4px;
        }
        textarea {
            resize: vertical;
        }
        .submit-container {
            display: flex;
            justify-content: center;
            margin-top: 20px;
        }
        button {
            background-color: #2c2c8f;
            color: white;
            padding: 10px 40px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
        }
        button:hover {
            background-color: #24246b;
        }
    </style>
</head>
<body>
<div class="container">
    <h2>Create New Project</h2>
    <label for="due-date">Set project due date:</label>
    <div class="date-group">
        <select id="month">
            <option>Month</option>
        </select>
        <select id="day">
            <option>Day</option>
        </select>
        <select id="year">
            <option>Year</option>
        </select>
    </div>

    <div class="form-group">
        <div>
            <label for="project-name">Project Name</label>
            <input type="text" id="project-name">

            <label for="project-manager">Project Manager</label>
            <input type="text" id="project-manager">

            <label for="team-members">Team Members</label>
            <select id="team-members" multiple>
                <option value="member1">Member 1</option>
                <option value="member2">Member 2</option>
                <option value="member3">Member 3</option>
                <option value="member4">Member 4</option>
            </select>

            <label for="description">Project Description</label>
            <textarea id="description"></textarea>
        </div>

        <div>
            <label for="risks">Project Risks</label>
            <textarea id="risks"></textarea>

            <label for="function-requirements">Function Requirements</label>
            <textarea id="function-requirements"></textarea>

            <label for="non-function-requirements">Non-Function Requirements</label>
            <textarea id="non-function-requirements"></textarea>
        </div>
    </div>

    <div class="submit-container">
        <button type="submit">Submit</button>
    </div>
</div>

<script>
    $(document).ready(function() {
        $('#team-members').select2({
            placeholder: "Select team members",
            allowClear: true
        });
    });
</script>
</body>
</html>

<a asp-action="Index">Back to List</a>